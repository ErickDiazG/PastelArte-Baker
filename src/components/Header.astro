---
// Header Component with Mobile Hamburger Menu
---
<header class="sticky top-0 z-50 bg-cream backdrop-blur-md shadow-sm border-b border-accent/20 w-full">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20 transition-all duration-300">
      
      <!-- Brand & Logo -->
      <div class="flex items-center gap-3">
        <a href="/" class="flex flex-row items-center gap-2 group relative z-[70]">
          <div class="w-10 h-10 md:w-12 md:h-12 overflow-hidden rounded-full border-2 border-accent group-hover:scale-105 transition-transform shadow-sm">
            <img src="/images/PastelArte.webp" alt="PastelArte Logo" class="w-full h-full object-cover" width="48" height="48" />
          </div>
          <span class="text-xl md:text-2xl font-brand font-bold tracking-tight">
            <span class="text-choco">Pastel</span><span class="text-cta">Arte</span>
          </span>
        </a>
      </div>
      
      <!-- Center Desktop Navigation -->
      <nav class="hidden md:flex space-x-8" aria-label="Navegación principal">
        <a href="/" class="text-choco font-brand font-bold text-lg hover:text-cta transition-colors py-2">Inicio</a>
        <a href="/menu" class="text-choco font-brand font-bold text-lg hover:text-cta transition-colors py-2">Menú</a>
        <a href="/#about" class="text-choco font-brand font-bold text-lg hover:text-cta transition-colors py-2">Sobre Faty</a>
        <a href="/#faq" class="text-choco font-brand font-bold text-lg hover:text-cta transition-colors py-2">FAQ</a>
        <a href="https://wa.me/528994719925" target="_blank" rel="noopener noreferrer" class="text-choco font-brand font-bold text-lg hover:text-cta transition-colors py-2">Contacto</a>
      </nav>

      <!-- Right: CTA + Hamburger -->
      <div class="flex items-center gap-3">
        <!-- CTA WhatsApp Button -->
        <a href="https://wa.me/528994719925" target="_blank" rel="noopener noreferrer" class="bg-cta text-white font-bold px-6 py-2.5 rounded-full hover:bg-[#D62828] transition-colors shadow-md hover:shadow-lg whitespace-nowrap hidden sm:inline-flex relative z-[70]">
          ¡Quiero pedir!
        </a>

        <!-- Hamburger Button (Mobile) -->
        <button 
          id="menu-toggle" 
          class="md:hidden flex items-center justify-center w-11 h-11 rounded-lg hover:bg-accent/20 transition-colors relative z-[70]"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-300">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="close-icon" class="hidden transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      
    </div>
  </div>
</header>

<!-- Mobile Menu Panel (Overlay) - Moved outside header for absolute reliably fixed positioning -->
<nav 
  id="mobile-menu" 
  class="fixed inset-0 z-[100] bg-[#FFFDF7] translate-x-full transition-transform duration-500 ease-in-out md:hidden flex flex-col items-center justify-center pointer-events-none"
  aria-label="Navegación móvil"
  style="background-color: #FFFDF7 !important;"
>
  <div class="flex flex-col items-center gap-8 w-full px-8 -mt-20">
    <a href="/" class="mobile-nav-link text-choco font-brand font-bold text-4xl hover:text-cta transition-colors py-2 w-full text-center">Inicio</a>
    <a href="/menu" class="mobile-nav-link text-choco font-brand font-bold text-4xl hover:text-cta transition-colors py-2 w-full text-center">Menú</a>
    <a href="/#about" class="mobile-nav-link text-choco font-brand font-bold text-4xl hover:text-cta transition-colors py-2 w-full text-center">Sobre Faty</a>
    <a href="/#faq" class="mobile-nav-link text-choco font-brand font-bold text-4xl hover:text-cta transition-colors py-2 w-full text-center">FAQ</a>
    <a href="https://wa.me/528994719925" target="_blank" rel="noopener noreferrer" class="bg-cta text-white font-bold text-xl py-4 px-10 rounded-full hover:bg-[#D62828] transition-colors text-center mt-8 shadow-xl w-full max-w-sm">
      ¡Quiero pedir! ✨
    </a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  function toggleMenu() {
    const isOpening = menu?.classList.contains('translate-x-full');
    
    if (isOpening) {
      menu?.classList.remove('translate-x-full', 'pointer-events-none');
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden'; // Lock scroll
    } else {
      menu?.classList.add('translate-x-full', 'pointer-events-none');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = ''; // Unlock scroll
    }
    
    toggle?.setAttribute('aria-expanded', isOpening ? 'true' : 'false');
  }

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // Close menu when clicking a navigation link
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (!menu?.classList.contains('translate-x-full')) {
        toggleMenu();
      }
    });
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('translate-x-full')) {
      toggleMenu();
    }
  });
</script>
