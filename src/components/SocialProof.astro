---
// SocialProof Component
const testimonials = [
  {
    name: "Ana García",
    text: "¡Los pasteles de huellita son lo máximo! Pedí uno para el cumpleaños de mi hija y nos encantó la decoración y el sabor a vainilla.",
    pawRating: 5,
    color: "bg-[#FFD1DC]" // Pastel pink
  },
  {
    name: "Carlos M.",
    text: "Las michi-galletas son mi adicción los fines de semana. Súper crujientes por fuera y suaves por dentro. 10/10.",
    pawRating: 5,
    color: "bg-[#AEC6CF]" // Pastel blue
  },
  {
    name: "Sofía T.",
    text: "Excelente servicio y los brownies son una locura. Jaque tiene un don increíble para la repostería. ¡Volveré a pedir seguro!",
    pawRating: 5,
    color: "bg-[#CFCFC4]" // Pastel beige
  },
  {
    name: "Daniela R.",
    text: "Hicieron mi pedido súper rápido y además de tiernos, estaban riquísimos. Todo súper higiénico y bien presentado.",
    pawRating: 5,
    color: "bg-[#B2EBF2]" // Pastel mint
  }
];

// Helper to render paw svgs based on count
---

<section class="py-20 lg:py-32 bg-cream px-4 sm:px-6 lg:px-8 border-y border-accent/20 overflow-hidden relative">
  <!-- Decorative Floating Paws -->
  <div class="absolute opacity-5 top-10 left-10 w-24 h-24 paw-bg">
    <svg viewBox="0 0 100 100" class="fill-choco"><path d="M50 85 C30 85, 20 65, 25 50 C30 35, 70 35, 75 50 C80 65, 70 85, 50 85 Z" /><circle cx="25" cy="35" r="10" /><circle cx="40" cy="20" r="11" /><circle cx="60" cy="20" r="11" /><circle cx="75" cy="35" r="10" /></svg>
  </div>
  <div class="absolute opacity-5 bottom-10 right-10 w-32 h-32 paw-bg-2">
    <svg viewBox="0 0 100 100" class="fill-choco"><path d="M50 85 C30 85, 20 65, 25 50 C30 35, 70 35, 75 50 C80 65, 70 85, 50 85 Z" /><circle cx="25" cy="35" r="10" /><circle cx="40" cy="20" r="11" /><circle cx="60" cy="20" r="11" /><circle cx="75" cy="35" r="10" /></svg>
  </div>

  <!-- Decorative Stickers -->
  <div class="absolute top-20 right-1/4 text-2xl animate-float-slow">✨</div>
  <div class="absolute bottom-20 left-1/4 text-2xl animate-float">💖</div>

  <div class="max-w-6xl mx-auto z-10 relative">
    
    <div class="text-center mb-16 relative">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-brand font-bold text-choco mb-4 inline-block relative">
        Lo que dicen los "Catadores"
        <span class="absolute -top-4 -right-8 text-xl rotate-[15deg] animate-pulse">😻</span>
      </h2>
      <p class="text-lg text-choco/70 font-body max-w-xl mx-auto">
        No lo decimos solo nosotros, nuestros clientes lo confirman.
      </p>
    </div>

    <!-- Infinite Scroll Marquee Container -->
    <!-- We duplicate the inner content to create seamless loop -->
    <div class="relative w-full overflow-hidden flex pb-8 group mt-8 testimonial-track" style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
      <!-- First track -->
      <div class="animate-marquee flex gap-6 shrink-0 group-hover:[animation-play-state:paused] pr-6">
        {testimonials.map((t) => (
          <div class="w-[300px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-8 rounded-[2rem] shadow-sm border border-accent/10 flex flex-col hover:shadow-xl transition-all duration-300 hover:-translate-y-2 cursor-grab active:cursor-grabbing relative overflow-hidden">
            
            <!-- Paws Rating -->
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.pawRating }).map(() => (
                <svg viewBox="0 0 100 100" class="w-6 h-6 fill-cta">
                  <path d="M50 85 C30 85, 20 65, 25 50 C30 35, 70 35, 75 50 C80 65, 70 85, 50 85 Z" />
                  <circle cx="25" cy="35" r="10" />
                  <circle cx="40" cy="20" r="11" />
                  <circle cx="60" cy="20" r="11" />
                  <circle cx="75" cy="35" r="10" />
                </svg>
              ))}
            </div>
            
            <p class="text-choco/80 font-body italic mb-6 flex-1 text-lg relative z-10">
              "{t.text}"
            </p>
            
            <div class="flex items-center gap-4 mt-auto">
               <!-- Cute cat avatar -->
               <div class={`w-12 h-12 rounded-full ${t.color} text-choco flex items-center justify-center font-bold font-brand text-xl shadow-inner relative border-2 border-white`}>
                  {t.name.charAt(0)}
                  <!-- Orejitas -->
                  <div class={`absolute -top-1.5 -left-1 w-3 h-3 ${t.color} rounded-sm rotate-[-15deg]`}></div>
                  <div class={`absolute -top-1.5 -right-1 w-3 h-3 ${t.color} rounded-sm rotate-[15deg]`}></div>
               </div>
               <span class="font-bold text-choco font-brand text-lg">{t.name}</span>
            </div>
          </div>
        ))}
      </div>
      <!-- Duplicate track for seamless loop -->
      <div class="animate-marquee flex gap-6 shrink-0 group-hover:[animation-play-state:paused] pr-6" aria-hidden="true">
        {testimonials.map((t) => (
          <div class="w-[300px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-8 rounded-[2rem] shadow-sm border border-accent/10 flex flex-col hover:shadow-xl transition-all duration-300 hover:-translate-y-2 cursor-grab active:cursor-grabbing relative overflow-hidden">
            
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.pawRating }).map(() => (
                <svg viewBox="0 0 100 100" class="w-6 h-6 fill-cta">
                  <path d="M50 85 C30 85, 20 65, 25 50 C30 35, 70 35, 75 50 C80 65, 70 85, 50 85 Z" />
                  <circle cx="25" cy="35" r="10" />
                  <circle cx="40" cy="20" r="11" />
                  <circle cx="60" cy="20" r="11" />
                  <circle cx="75" cy="35" r="10" />
                </svg>
              ))}
            </div>
            
            <p class="text-choco/80 font-body italic mb-6 flex-1 text-lg relative z-10">
              "{t.text}"
            </p>
            
            <div class="flex items-center gap-4 mt-auto">
               <div class={`w-12 h-12 rounded-full ${t.color} text-choco flex items-center justify-center font-bold font-brand text-xl shadow-inner relative border-2 border-white`}>
                  {t.name.charAt(0)}
                  <div class={`absolute -top-1.5 -left-1 w-3 h-3 ${t.color} rounded-sm rotate-[-15deg]`}></div>
                  <div class={`absolute -top-1.5 -right-1 w-3 h-3 ${t.color} rounded-sm rotate-[15deg]`}></div>
               </div>
               <span class="font-bold text-choco font-brand text-lg">{t.name}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  
  <style>
    /* Continuous Marquee Animation */
    .animate-marquee {
      animation: marquee 30s linear infinite;
    }
    
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-100%); }
    }

    /* Floating animations for background paws */
    .paw-bg {
      animation: float 6s ease-in-out infinite alternate;
      transform-origin: center;
    }
    @keyframes float {
      0% { transform: translateY(0) rotate(12deg); }
      100% { transform: translateY(-20px) rotate(18deg); }
    }

    .paw-bg-2 {
      animation: float-rev 8s ease-in-out infinite alternate;
      transform-origin: center;
    }
    @keyframes float-rev {
      0% { transform: translateY(0) rotate(-12deg); }
      100% { transform: translateY(20px) rotate(-18deg); }
    }

    /* Sticker animations */
    .animate-float {
      animation: floating 3s ease-in-out infinite alternate;
    }
    .animate-float-slow {
      animation: floating 4.5s ease-in-out infinite alternate-reverse;
    }
    @keyframes floating {
      0% { transform: translateY(0); }
      100% { transform: translateY(-15px); }
    }
  </style>
</section>
