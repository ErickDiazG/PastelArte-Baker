---
// Footer Component
---

<footer class="bg-choco text-cream py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col items-center">
    
    <!-- Big CTA -->
    <div class="w-full bg-cream rounded-[3rem] p-10 lg:p-16 text-center shadow-lg relative overflow-hidden mb-16 max-w-4xl mx-auto border-4 border-accent">
      <div class="relative z-10">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-brand font-bold text-choco mb-6">
          ¿Listo para endulzar tu día?
        </h2>
        <p class="text-lg text-choco/80 font-body mb-8 max-w-xl mx-auto">
          Mándame un mensaje por WhatsApp y hagamos realidad ese postre que tienes en mente.
        </p>
        <a href="https://wa.me/5211234567890" target="_blank" rel="noopener noreferrer" class="bg-cta text-white font-bold text-xl px-10 py-5 rounded-full hover:bg-[#fa8b61] transition-all shadow-xl hover:shadow-2xl transform hover:-translate-y-1 inline-flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          ¡Quiero mi postre!
        </a>
      </div>
      <!-- Paws for big CTA -->
      <div class="absolute opacity-10 top-0 left-0 w-32 h-32 -translate-x-10 -translate-y-10 rotate-45"><svg viewBox="0 0 100 100" class="fill-choco"><path d="M50 85 C30 85, 20 65, 25 50 C30 35, 70 35, 75 50 C80 65, 70 85, 50 85 Z" /><circle cx="25" cy="35" r="10" /><circle cx="40" cy="20" r="11" /><circle cx="60" cy="20" r="11" /><circle cx="75" cy="35" r="10" /></svg></div>
      <div class="absolute opacity-10 bottom-0 right-0 w-40 h-40 translate-x-10 translate-y-10 -rotate-45"><svg viewBox="0 0 100 100" class="fill-choco"><path d="M50 85 C30 85, 20 65, 25 50 C30 35, 70 35, 75 50 C80 65, 70 85, 50 85 Z" /><circle cx="25" cy="35" r="10" /><circle cx="40" cy="20" r="11" /><circle cx="60" cy="20" r="11" /><circle cx="75" cy="35" r="10" /></svg></div>
    </div>

    <!-- Links and Logo -->
    <div class="w-full flex flex-col md:flex-row justify-between items-center gap-8 border-b border-cream/20 pb-12">
      
      <div class="flex items-center gap-3">
         <div class="w-12 h-12 bg-cream rounded-full overflow-hidden border border-cream/20">
            <img src="/images/logo.png" alt="Logo" class="w-full h-full object-cover">
         </div>
         <span class="text-2xl font-brand font-bold text-cream">Jaque Postres</span>
      </div>

      <nav class="flex space-x-6">
        <a href="#menu" class="hover:text-accent transition-colors font-bold">Menú</a>
        <a href="#about" class="hover:text-accent transition-colors font-bold">Nosotros</a>
        <a href="#faq" class="hover:text-accent transition-colors font-bold">FAQ</a>
      </nav>

      <div class="flex space-x-4">
        <a href="#" class="w-10 h-10 bg-cream/10 rounded-full flex items-center justify-center hover:bg-accent hover:text-choco transition-all" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a href="#" class="w-10 h-10 bg-cream/10 rounded-full flex items-center justify-center hover:bg-accent hover:text-choco transition-all" aria-label="TikTok">
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="w-full text-center mt-8 pt-4">
      <p class="text-cream/70 font-body text-sm">
        Horneado con 💖 en Reynosa. © {new Date().getFullYear()} Jaque Postres.
      </p>
    </div>
  </div>
</footer>
