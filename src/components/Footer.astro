    <!-- Bottom credit bar -->
    <div class="w-full flex flex-col sm:flex-row justify-between items-center gap-3 pt-5">
      <p class="footer-love text-cream/90 font-body text-sm cursor-default group">
        Horneado con <span class="footer-heart inline-block">💖</span> en Reynosa
      </p>
      <a href="https://devdiazlabs.com" target="_blank" rel="noopener noreferrer" class="footer-brand text-cream/40 font-body text-xs min-h-[44px] inline-flex items-center">
        Desarrollado por <span class="footer-brand-name ml-1">DevDiaz Labs</span>
      </a>
