  </div>
</footer>

<style>
  /* Heart bounce animation on hover */
  .footer-love:hover .footer-heart {
    animation: heartBounce 0.6s ease-in-out infinite;
  }

  @keyframes heartBounce {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.4) rotate(-10deg); }
    50% { transform: scale(1) rotate(0deg); }
    75% { transform: scale(1.3) rotate(10deg); }
  }

  /* Subtle text glow on the whole line */
  .footer-love {
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }

  .footer-love:hover {
    color: rgba(255, 253, 247, 1);
    text-shadow: 0 0 12px rgba(255, 182, 193, 0.4);
  }

  /* DevDiaz Labs brand hover */
  .footer-brand {
    transition: color 0.3s ease;
  }

  .footer-brand:hover {
    color: rgba(255, 253, 247, 0.7);
  }

  .footer-brand-name {
    position: relative;
    transition: color 0.3s ease, text-shadow 0.3s ease, letter-spacing 0.3s ease;
  }

  .footer-brand:hover .footer-brand-name {
    color: #f5a574;
    text-shadow: 0 0 10px rgba(245, 165, 116, 0.5), 0 0 20px rgba(245, 165, 116, 0.2);
    letter-spacing: 0.5px;
  }

  /* Sparkle underline effect */
  .footer-brand-name::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #f5a574, transparent);
    transition: width 0.4s ease;
  }

  .footer-brand:hover .footer-brand-name::after {
    width: 100%;
  }
</style>
