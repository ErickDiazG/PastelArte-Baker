---
// Botón flotante para acceder al carrito en móviles u otras páginas
---
<button id="floating-cart-btn" class="fixed bottom-6 right-6 z-50 bg-choco text-cream w-14 h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.2)] flex items-center justify-center hover:bg-cta hover:-translate-y-1 hover:scale-105 transition-all duration-300 group border-2 border-white/20" aria-label="Abrir carrito de compras">
  <div class="relative">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="stroke-current stroke-2 group-hover:rotate-12 transition-transform"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
    <span id="cart-badge" class="absolute -top-3 -right-3 bg-cta text-white text-[11px] font-bold w-6 h-6 flex items-center justify-center rounded-full scale-0 transition-transform duration-300 border-[2.5px] border-cream pointer-events-none shadow-sm">
      0
    </span>
  </div>
</button>

<script>
  import { CartStore } from '../scripts/cartStore.js';
  
  const btn = document.getElementById('floating-cart-btn');
  const badge = document.getElementById('cart-badge');
  
  btn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-cart'));
  });

  function updateBadge(cart) {
    if (!badge) return;
    const total = CartStore.getTotalItems();
    if (total > 0) {
      badge.textContent = total.toString();
      badge.classList.remove('scale-0');
      badge.classList.add('scale-100');
    } else {
      badge.classList.remove('scale-100');
      badge.classList.add('scale-0');
    }
  }

  window.addEventListener('cart-updated', ((e: CustomEvent) => {
    updateBadge(e.detail);
  }) as EventListener);
  
  document.addEventListener('DOMContentLoaded', () => {
    updateBadge(CartStore.getCart());
  });
</script>
