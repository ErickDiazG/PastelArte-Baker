---
// Hero Component — Optimized
---

<section class="relative pt-16 pb-20 lg:pt-24 lg:pb-32 overflow-hidden px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
    
    <!-- Text Content -->
    <div class="w-full lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left z-10">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-brand font-bold text-choco leading-tight mb-6">
        Postres hechos con amor y un toque de ronroneos. 🐾
      </h1>
      <p class="text-lg sm:text-xl text-choco/80 font-body mb-8 max-w-2xl">
        Endulza tu día en Reynosa con los pasteles y galletas más tiernos de la ciudad.
      </p>
      <a href="#menu" class="bg-cta text-white font-bold text-lg px-8 py-4 rounded-full hover:bg-[#fa8b61] transition-colors shadow-lg hover:shadow-xl inline-block">
        Ver el menú delicioso
      </a>
    </div>

    <!-- Image & Animation Container -->
    <div class="w-full lg:w-1/2 relative z-10 flex justify-center mt-10 lg:mt-0">
      <div class="relative w-full max-w-md aspect-square rounded-[3rem] overflow-hidden shadow-2xl border-4 border-white">
        <img 
          src="/images/hero-cake.webp" 
          alt="Pastel decorado con temática de gato, postre estrella de Jaque Postres" 
          class="w-full h-full object-cover"
          width="500"
          height="500"
        />
        
        <!-- Cat Paw Animation -->
        <div class="paw-container absolute -bottom-16 -right-16 w-32 h-32 rotate-[-45deg] z-20 cursor-pointer" aria-hidden="true">
          <svg viewBox="0 0 100 100" class="w-full h-full fill-[#4A3022] drop-shadow-lg">
            <use href="#paw" />
            <!-- Arm connecting pad to bottom edge -->
            <rect x="25" y="60" width="50" height="40" class="fill-[#4A3022]" />
          </svg>
        </div>
      </div>
      
      <!-- Decorative Elements -->
      <div class="absolute -top-10 -right-10 w-24 h-24 bg-accent/30 rounded-full blur-2xl z-0" aria-hidden="true"></div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-cta/20 rounded-full blur-2xl z-0" aria-hidden="true"></div>
    </div>
  </div>
  
  <style>
    .paw-container {
      animation: sneaky-paw 4s infinite alternate ease-in-out;
      transform-origin: bottom right;
      will-change: transform;
    }
    
    @keyframes sneaky-paw {
      0%, 60% {
        transform: translate(0, 0) rotate(0deg);
      }
      80% {
        transform: translate(-3rem, -3rem) rotate(-10deg);
      }
      100% {
        transform: translate(-3.5rem, -3.5rem) rotate(-15deg);
      }
    }
  </style>
</section>
