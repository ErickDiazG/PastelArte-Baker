---
// Menu Component
const menuItems = [
  {
    title: "Michi-Galletas",
    description: "Galletas decoradas y chocochips, horneadas con mucho cariño para alegrar tu día.",
    image: "/images/michi-galletas.png",
    whatsappLink: "https://wa.me/5211234567890?text=Hola,%20quiero%20pedir%20unas%20Michi-Galletas",
    tag: "Galletas",
  },
  {
    title: "Pasteles de Huellita",
    description: "Pasteles completos para cumpleaños o celebraciones especiales. ¡Súper esponjosos!",
    image: "/images/pastel-huellita.png",
    whatsappLink: "https://wa.me/5211234567890?text=Hola,%20quiero%20pedir%20un%20Pastel%20de%20Huellita",
    tag: "Celebración",
  },
  {
    title: "Antojos de un Zarpazo",
    description: "Postres individuales: brownies fudgy, cupcakes y más para ese antojo de media tarde.",
    image: "/images/antojo-zarpazo.png",
    whatsappLink: "https://wa.me/5211234567890?text=Hola,%20quiero%20pedir%20un%20Antojo%20de%20un%20Zarpazo",
    tag: "Individual",
  }
];
---

<section id="menu" class="py-20 lg:py-32 bg-white px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-brand font-bold text-choco mb-4">
        Nuestro Menú Delicioso
      </h2>
      <p class="text-lg text-choco/70 font-body max-w-2xl mx-auto">
        Hechos desde cero, con ingredientes de calidad y mucho amor. ¿Qué se te antoja hoy?
      </p>
    </div>

    <!-- Menu Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {menuItems.map((item) => (
        <div class="bg-cream rounded-[2rem] overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-accent/20 group flex flex-col items-center p-6 sm:p-8">
          
          <!-- Image Container -->
          <div class="w-full aspect-square rounded-[1.5rem] overflow-hidden mb-6 relative">
            <div class="absolute top-4 left-4 z-10 bg-white/90 backdrop-blur-sm text-choco font-bold text-sm px-3 py-1 rounded-full shadow-sm">
              {item.tag}
            </div>
            <img 
              src={item.image} 
              alt={item.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          
          <!-- Content -->
          <div class="flex flex-col flex-1 w-full text-center">
            <h3 class="text-2xl font-brand font-bold text-choco mb-3">
              {item.title}
            </h3>
            <p class="text-choco/80 font-body mb-8 flex-1">
              {item.description}
            </p>
            
            <a 
              href={item.whatsappLink} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="w-full bg-accent/30 text-choco hover:text-white font-bold py-3 px-6 rounded-full hover:bg-cta transition-colors border border-accent/50 text-center flex items-center justify-center gap-2 group-hover:border-transparent"
            >
              <span>¡Pedir por WhatsApp!</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="stroke-current stroke-2 group-hover:translate-x-1 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Ver menú completo -->
    <div class="text-center mt-14">
      <a href="/menu" class="bg-cta text-white font-bold text-lg px-10 py-4 rounded-full hover:bg-[#fa8b61] transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-1 inline-flex items-center gap-3">
        Ver menú completo
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="stroke-current stroke-2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
    
  </div>
</section>
