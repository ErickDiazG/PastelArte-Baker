---

<Layout title="Menú Completo | PastelArte">
  <Header />
  <main>
    <!-- Page Hero -->
    <section class="pt-12 pb-8 lg:pt-16 lg:pb-12 px-4 sm:px-6 lg:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-accent/15 text-choco/80 text-sm font-body font-semibold px-5 py-2 rounded-full mb-6">
          <svg viewBox="0 0 100 100" class="w-5 h-5 fill-cta" aria-hidden="true"><use href="#sparkle" /></svg>
          Menú completo
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-brand font-bold text-choco mb-4">
          Nuestro Menú Completo
        </h1>
        <p class="text-lg sm:text-xl text-choco/70 font-body max-w-2xl mx-auto">
          Explora todos nuestros postres hechos con amor. ¿Ya sabes qué se te antoja? ¡Pide por WhatsApp!
        </p>
      </div>
    </section>
    
    <!-- Category Tabs (Sticky) -->
    <nav class="sticky top-20 z-40 bg-cream/95 backdrop-blur-sm border-y border-accent/20 py-3 px-4 sm:px-6 lg:px-8" aria-label="Categorías del menú">
      <div class="max-w-4xl mx-auto flex justify-center gap-2 sm:gap-4 overflow-x-auto scrollbar-hide">
        {categories.map((cat, i) => (
          <button 
            data-target={cat.id}
            class={`tab-btn flex items-center gap-2 px-4 sm:px-6 py-2.5 rounded-full font-brand font-bold text-sm sm:text-base transition-colors whitespace-nowrap min-h-[44px] shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-accent ${i === 0 ? 'bg-cta text-white border-transparent' : 'text-choco/80 hover:text-choco bg-white/60 hover:bg-white border border-accent/20 hover:border-accent/40'}`}
          >
            <span aria-hidden="true">{cat.emoji}</span>
            <span>{cat.name}</span>
          </button>
        ))}
      </div>
    </nav>

    <!-- Menu Sections -->
    <div id="tabs-container">
      {categories.map((category, i) => (
        <section id={category.id} class={`tab-section py-16 lg:py-20 px-4 sm:px-6 lg:px-8 animate-fade-in ${i === 0 ? 'block' : 'hidden'}`} style={i % 2 === 0 ? "background-color: #FFFDF7;" : "background-color: white;"}>
        <div class="max-w-6xl mx-auto">

          <!-- Category Header -->
          <div class="text-center mb-12">
            <span class="text-4xl mb-3 block" aria-hidden="true">{category.emoji}</span>
            <h2 class="text-3xl sm:text-4xl font-brand font-bold text-choco mb-3">
              {category.name}
            </h2>
            <p class="text-lg text-choco/60 font-body max-w-xl mx-auto">
              {category.description}
            </p>
          </div>

          <!-- Product Grid -->
          <div class="menu-product-grid" style="display:grid;gap:1.5rem;">
            {category.items.map((item) => (
              <div class="group bg-cream rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-accent/15 flex flex-col reveal-up delay-100">
                
                <!-- Product Image -->
                <div class="aspect-square overflow-hidden relative">
                  <img 
                    src={item.image} 
                    alt={item.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    width="300"
                    height="300"
                  />
                  <!-- Price Badge -->
                  <div class="absolute top-3 right-3 bg-choco/90 text-cream font-brand font-bold text-sm px-3 py-1.5 rounded-full shadow-lg">
                    {item.price}
                  </div>
                </div>

                <!-- Product Info -->
                <div class="p-5 flex flex-col flex-1">
                  <h3 class="text-lg font-brand font-bold text-choco mb-2 leading-snug">
                    {item.name}
                  </h3>
                  <p class="text-sm text-choco/70 font-body mb-5 flex-1 leading-relaxed">
                    {item.description}
                  </p>
                  <div class="flex gap-2 w-full mt-auto pt-4 border-t border-accent/10">
                    <button 
                      class="add-to-cart-btn flex-[1] bg-cream text-cta border-2 border-cta font-bold py-2 px-1 sm:px-2 rounded-xl border-dashed hover:bg-cta hover:text-white transition-colors text-center text-sm flex items-center justify-center gap-1 min-h-[44px]"
                      data-name={item.name}
                      data-image={item.image}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="stroke-current stroke-2"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/><path d="M12 8v6"/><path d="M9 11h6"/></svg>
                      Añadir
                    </button>
                    <a 
                      href={item.whatsapp}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-full flex-[1.5] bg-cta text-white font-bold py-2 px-1 sm:px-2 rounded-xl hover:bg-[#D62828] transition-colors text-center text-sm flex items-center justify-center gap-1 min-h-[44px]"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                      Pedir
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
      ))}
    </div>



    <!-- Back to Home -->
    <div class="text-center py-8 bg-cream">
      <a href="/" class="text-choco/60 hover:text-cta font-brand font-bold text-lg transition-colors inline-flex items-center gap-2 min-h-[44px]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="stroke-current stroke-2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Volver al inicio
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Responsive grid — injected at runtime to avoid Tailwind/Astro stripping
  const style = document.createElement('style');
  style.textContent = `
    .menu-product-grid { display:grid; grid-template-columns:1fr; gap:1.5rem; }
    .scrollbar-hide { -ms-overflow-style:none; scrollbar-width:none; }
    .scrollbar-hide::-webkit-scrollbar { display:none; }
    @media(min-width:640px) { .menu-product-grid { grid-template-columns:repeat(2,1fr); } }
    @media(min-width:1024px) { .menu-product-grid { grid-template-columns:repeat(4,1fr); gap:2rem; } }
  `;
  document.head.appendChild(style);
</script>

</script>

<script>
  // TABS LOGIC
  function initTabs() {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabSections = document.querySelectorAll('.tab-section');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        
        // Hide all sections
        tabSections.forEach(section => {
          section.classList.add('hidden');
          section.classList.remove('block');
        });
        
        // Reset button styles
        tabBtns.forEach(b => {
          b.className = 'tab-btn flex items-center gap-2 px-4 sm:px-6 py-2.5 rounded-full font-brand font-bold text-sm sm:text-base transition-colors whitespace-nowrap min-h-[44px] shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-accent text-choco/80 hover:text-choco bg-white/60 hover:bg-white border border-accent/20 hover:border-accent/40';
        });

        // Show target section
        const targetSection = document.getElementById(targetId);
        if (targetSection) {
          targetSection.classList.remove('hidden');
          targetSection.classList.add('block');
        }

        // Apply active style to clicked button
        btn.className = 'tab-btn flex items-center gap-2 px-4 sm:px-6 py-2.5 rounded-full font-brand font-bold text-sm sm:text-base transition-colors whitespace-nowrap min-h-[44px] shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-accent bg-cta text-white border-transparent';
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initTabs);
</script>

<script>
  import { CartStore } from '../scripts/cartStore.js';
  
  function initCartButtons() {
    const buttons = document.querySelectorAll('.add-to-cart-btn');
    buttons.forEach(btn => {
      // Avoid re-attaching
      if (btn.hasAttribute('data-initialized')) return;
      btn.setAttribute('data-initialized', 'true');
      
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget as HTMLButtonElement;
        const item = {
          name: target.dataset.name,
          image: target.dataset.image
        };
        CartStore.addItem(item);
        
        const originalText = target.innerHTML;
        target.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> ¡Añadido!`;
        target.classList.replace('text-cta', 'text-white');
        target.classList.replace('bg-cream', 'bg-[#10b981]');
        target.classList.replace('border-cta', 'border-[#10b981]');
        
        setTimeout(() => {
          target.innerHTML = originalText;
          target.classList.replace('text-white', 'text-cta');
          target.classList.replace('bg-[#10b981]', 'bg-cream');
          target.classList.replace('border-[#10b981]', 'border-cta');
        }, 1500);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initCartButtons);
</script>
<style>
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
